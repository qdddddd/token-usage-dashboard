# Server
PORT=8080

# Comma-separated provider IDs: openai, anthropic, right-code, micu, packy, custom
# Providers use your existing Edge profile - just log in to Edge manually!
PROVIDERS=right-code,micu,packy

# Edge Profile for Scraping
# Optional: Use a separate Edge profile for the dashboard to avoid conflicts
# If not set, uses the default Edge profile
# Example: /home/username/.config/microsoft-edge-dashboard
EDGE_PROFILE_PATH=

# Right Code provider
# Optional: multiply cost by this factor (e.g., if costs are in CNY, use 0.14 for USD conversion)
RIGHT_CODE_COST_MULTIPLIER=1
# Optional: override provider ID in response
RIGHT_CODE_PROVIDER_ID=right-code

# Micu provider
# Optional: override provider ID in response
MICU_PROVIDER_ID=micu

# Packy provider
# Optional: override provider ID in response
PACKY_PROVIDER_ID=packy

# Custom provider (optional, API-based)
# Endpoint must return:
# {
#   "daily": [{"date":"YYYY-MM-DD","inputTokens":0,"outputTokens":0,"totalTokens":0,"queryCount":0,"costUsd":0}],
#   "account": {"balanceRemainingUsd":0,"balanceExpirationDate":"YYYY-MM-DD"}
# }
CUSTOM_PROVIDER_URL=
CUSTOM_PROVIDER_API_KEY=
CUSTOM_PROVIDER_DASHBOARD_URL=
